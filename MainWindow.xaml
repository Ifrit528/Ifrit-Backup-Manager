<Window x:Class="Backup_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Backup_Manager"
        Loaded="Window_Loaded"
        Title="Backup Manager" Height="450" Width="800">

    <Window.Resources>
        <DataTemplate x:Key="ListItemTemplate">
            <StackPanel Orientation="Horizontal">
                <Button Grid.Column="0" Margin="30" VerticalAlignment="Center" Content="Button" Click="List_Button_Click"></Button>
                <TextBlock Grid.Column="1" Margin="30" VerticalAlignment="Center" TextWrapping="NoWrap" Text="{Binding Source}"/>
                <TextBlock Grid.Column="2" Margin="30" VerticalAlignment="Center" TextWrapping="NoWrap" Text="{Binding Destination}"/>
                <TextBlock Grid.Column="3" Margin="30" VerticalAlignment="Center" TextWrapping="NoWrap" Text="{Binding GetTime}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ListButton">
            <Button Content="Backup" Background="Green" Click="List_Button_Click" Margin="-10,0,0,0"/>
        </DataTemplate>

        <Style x:Key="HeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>


            <Grid Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.1*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <Grid Name="AddRemoveButtonGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Click="Add_Click" Grid.Row="0" Background="Green" Content="Add" FontWeight="Bold" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"></Button>
            <Button Click="Delete_Click" Grid.Row="0" Background="Red" Content="Delete" FontWeight="Bold" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"></Button>
        </Grid>

        <ListView Name="ListView1" ItemsSource="{Binding PathList, Mode=OneWay}" Background="#FF444444" Grid.Row="1">
            <ListView.View>
                <GridView>
                    <GridView.Columns>
                        <GridViewColumn Header="" Width="Auto" CellTemplate="{StaticResource ListButton}" HeaderContainerStyle="{StaticResource HeaderStyle}"/>
                        <GridViewColumn Header="Source" DisplayMemberBinding="{Binding Source}" Width="300" HeaderContainerStyle="{StaticResource HeaderStyle}"/>
                        <GridViewColumn Header="Destination" DisplayMemberBinding="{Binding Destination}" Width="300" HeaderContainerStyle="{StaticResource HeaderStyle}"/>
                        <GridViewColumn Header="Modified" DisplayMemberBinding="{Binding GetTime}" Width="100" HeaderContainerStyle="{StaticResource HeaderStyle}"/>
                    </GridView.Columns>
                </GridView>
            </ListView.View>
        </ListView>

    </Grid>
</Window>