<Window x:Class="Backup_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Backup_Manager"
        Loaded="Window_Loaded"
        Title="Backup Manager" Height="450" Width="1000">

    <Window.Resources>
        
        <Style x:Key="HeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TextBlockHover" TargetType="TextBlock">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="true">
                    <Setter Property="Foreground" Value="Gold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ListButton">
            <Button Content="Backup" Background="Green" Click="List_Button_Click" Margin="-10,0,0,0"/>
        </DataTemplate>

        <DataTemplate x:Key="SourceCell">
            <TextBlock Width="300" Text="{Binding Source}" MouseLeftButtonUp="Source_Click" Style="{StaticResource TextBlockHover}"/>
        </DataTemplate>
        
        <DataTemplate x:Key="DestinationCell">
            <TextBlock Width="300" Text="{Binding Destination}" MouseLeftButtonUp="Destination_Click" Style="{StaticResource TextBlockHover}"/>
        </DataTemplate>

    </Window.Resources>


            <Grid Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.1*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <Grid Name="AddRemoveButtonGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Click="Add_Click" Grid.Row="0" Background="Green" Foreground="Black" Content="Add" FontWeight="Bold" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Click="Edit_Click" Grid.Row="0" Background="Yellow" Foreground="Black" Content="Edit" FontWeight="Bold" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Click="Delete_Click" Grid.Row="0" Background="Red" Foreground="Black" Content="Delete" FontWeight="Bold" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <ListView Name="ListView1" ItemsSource="{Binding PathList, Mode=OneWay}" Background="#FF444444" Grid.Row="1">
            <ListView.View>
                <GridView>
                    <GridView.Columns>
                        <GridViewColumn Header="" Width="Auto" CellTemplate="{StaticResource ListButton}" HeaderContainerStyle="{StaticResource HeaderStyle}"/>
                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="100" HeaderContainerStyle="{StaticResource HeaderStyle}"/>
                        <GridViewColumn Header="Source" CellTemplate="{StaticResource SourceCell}" HeaderContainerStyle="{StaticResource HeaderStyle}"/>
                        <GridViewColumn Header="Destination" CellTemplate="{StaticResource DestinationCell}" HeaderContainerStyle="{StaticResource HeaderStyle}"/>
                        <GridViewColumn Header="Modified" DisplayMemberBinding="{Binding GetTime}" Width="Auto" HeaderContainerStyle="{StaticResource HeaderStyle}"/>
                    </GridView.Columns>
                </GridView>
            </ListView.View>
        </ListView>

    </Grid>
</Window>