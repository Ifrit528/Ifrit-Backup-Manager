<Window x:Class="Backup_Manager.AddButtonDialogue"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Backup_Manager"
        mc:Ignorable="d"
        Title="Select Source and Destination" Height="Auto" MaxHeight="300" Width="1000">
    <Grid>
        <StackPanel>
            <TextBlock Text="Name" FontWeight="Bold"/>
            <TextBox Name="NameBox" Width="900" Height="30" TextWrapping="NoWrap" HorizontalAlignment="Left"/>
            
            <TextBlock Text="Number of Backups" FontWeight="Bold"/>
            <TextBox Name="NumberOfBackups" Width="900" Height="30" TextWrapping="NoWrap" HorizontalAlignment="Left"/>
            
            <TextBlock Text="Source" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal">
                <TextBox Name="SourceResponseBox" Width="900" TextWrapping="NoWrap"/>
                <Button Height="40" Width="40" Click="SourceFolderDialogClick">
                    <Image Source="/resources/folder_icon.png" Width="Auto" Height="Auto"/>
                </Button>
            </StackPanel>
            
            <TextBlock Text="Destination" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal">
                <TextBox Name="DestinationResponseBox" Width="900" TextWrapping="NoWrap"/>
                <Button Height="40" Width="40" Click="DestinationFolderDialogClick">
                    <Image Source="/resources/folder_icon.png" Width="Auto" Height="Auto"/>
                </Button>
            </StackPanel>
            
            <Button Name="SubmitButton" Content="Submit" Click="SubmitClick"></Button>
        </StackPanel>
    </Grid>
</Window>
